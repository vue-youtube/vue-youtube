{
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "esnext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    // Skip checking until TS2300 error in source-map-js is resolved
    "skipLibCheck": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "paths": {
      "@vue-youtube/component": [
        "./packages/component/index.ts"
      ],
      "@vue-youtube/shared": [
        "./packages/shared/index.ts"
      ],
      "@vue-youtube/core": [
        "./packages/core/index.ts"
      ],
      "@vue-youtube/component/*": [
        "./packages/component/*"
      ],
      "@vue-youtube/shared/*": [
        "./packages/shared/*"
      ],
      "@vue-youtube/core/*": [
        "./packages/core/*"
      ],
    }
  },
  "include": [
    "packages",
  ],
  "exclude": [
    "packages/nuxt",
    "node_modules",
    "**/dist",
  ]
}